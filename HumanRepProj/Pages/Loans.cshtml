@page
@model HumanRepProj.Pages.LoansModel
@{
    ViewData["Title"] = "Loan Management";
    Layout = "_Layout";
}

@section Styles {
    <style>
        .status-pill {
            display: inline-flex;
            align-items: center;
            padding: 0.3rem 0.65rem;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.02em;
            border: 1px solid transparent;
        }

        .status-pill.pending {
            background: #fef3c7;
            color: #92400e;
            border-color: #fcd34d;
        }

        .status-pill.approved {
            background: #dcfce7;
            color: #166534;
            border-color: #86efac;
        }

        .status-pill.rejected {
            background: #fee2e2;
            color: #991b1b;
            border-color: #fca5a5;
        }

        .action-confirm-icon {
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            margin-bottom: 0.75rem;
        }

        .action-confirm-icon.approve {
            background: rgba(22, 163, 74, 0.15);
            color: #15803d;
        }

        .action-confirm-icon.reject {
            background: rgba(245, 158, 11, 0.18);
            color: #b45309;
        }

        .action-confirm-icon.delete {
            background: rgba(220, 38, 38, 0.15);
            color: #b91c1c;
        }
    </style>
}

<h2 class="mb-4">Manage Loans</h2>

@if (!string.IsNullOrWhiteSpace(Model.Message))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @Model.Message
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<!-- Admin Navigation -->
<nav aria-label="breadcrumb">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/Admin/Dashboard">Admin Dashboard</a></li>
        <li class="breadcrumb-item active" aria-current="page">Loan Management</li>
    </ol>
</nav>

<!-- Add New Loan Form -->


<!-- Loans Table -->
<div class="card">
    <div class="card-header bg-secondary text-white">
        Existing Loans
    </div>
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <thead class="thead-dark">
                <tr>
                    <th>Loan ID</th>
                    <th>Employee ID</th>
                    <th>Loan Type</th>
                    <th>Amount</th>
                    <th>Paid</th>
                    <th>Status</th>
                    <th>Issued</th>
                    <th>Due</th>
                    <th>Term</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.LoansList != null && Model.LoansList.Any())
                {
                    @foreach (var loan in Model.LoansList)
                    {
                        var statusClass = string.Equals(loan.LoanStatus, "Approved", System.StringComparison.OrdinalIgnoreCase)
                            ? "approved"
                            : string.Equals(loan.LoanStatus, "Rejected", System.StringComparison.OrdinalIgnoreCase)
                                ? "rejected"
                                : "pending";

                        <tr>
                            <td>@loan.LoanID</td>
                            <td>@loan.EmployeeID</td>
                            <td>@loan.LoanType</td>
                            <td>₱@loan.LoanAmount.ToString("N2")</td>
                            <td>₱@loan.PaidLoan.ToString("N2")</td>
                            <td><span class="status-pill @statusClass">@loan.LoanStatus</span></td>
                            <td>@loan.DateIssued.ToShortDateString()</td>
                            <td>@loan.DueDate.ToShortDateString()</td>
                            <td>@loan.LoanTerm months</td>
                            <td>
                                <div class="d-flex gap-1">
                                    @if (!string.Equals(loan.LoanStatus, "Approved", System.StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-page-handler="Approve" asp-route-id="@loan.LoanID" class="js-action-form" data-action="approve" data-name="Loan #@loan.LoanID">
                                            <button type="submit" class="btn btn-sm btn-success">Approve</button>
                                        </form>
                                    }
                                    @if (!string.Equals(loan.LoanStatus, "Rejected", System.StringComparison.OrdinalIgnoreCase))
                                    {
                                        <form method="post" asp-page-handler="Reject" asp-route-id="@loan.LoanID" class="js-action-form" data-action="reject" data-name="Loan #@loan.LoanID">
                                            <button type="submit" class="btn btn-sm btn-warning">Reject</button>
                                        </form>
                                    }
                                    <form method="post" asp-page-handler="Delete" asp-route-id="@loan.LoanID" class="js-action-form" data-action="delete" data-name="Loan #@loan.LoanID">
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted">No loans found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="actionConfirmModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-body text-center p-4">
                <div id="confirmActionIcon" class="action-confirm-icon approve">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h5 id="confirmActionTitle" class="mb-2">Confirm action</h5>
                <p id="confirmActionMessage" class="text-muted mb-4">Are you sure you want to continue?</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="confirmActionSubmit">Yes, continue</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const modalEl = document.getElementById('actionConfirmModal');
            const modal = new bootstrap.Modal(modalEl);
            const submitBtn = document.getElementById('confirmActionSubmit');
            const titleEl = document.getElementById('confirmActionTitle');
            const messageEl = document.getElementById('confirmActionMessage');
            const iconEl = document.getElementById('confirmActionIcon');
            let targetForm = null;

            document.querySelectorAll('.js-action-form').forEach(form => {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    targetForm = form;

                    const action = (form.dataset.action || '').toLowerCase();
                    const name = form.dataset.name || 'this request';

                    let title = 'Confirm action';
                    let message = 'Are you sure you want to continue?';
                    let buttonClass = 'btn-success';
                    let iconClass = 'approve';
                    let icon = 'bi-check-circle-fill';

                    if (action === 'approve') {
                        title = 'Approve Loan Request';
                        message = `Approve ${name}?`;
                        buttonClass = 'btn-success';
                        iconClass = 'approve';
                        icon = 'bi-check-circle-fill';
                    } else if (action === 'reject') {
                        title = 'Reject Loan Request';
                        message = `Reject ${name}?`;
                        buttonClass = 'btn-warning';
                        iconClass = 'reject';
                        icon = 'bi-slash-circle-fill';
                    } else if (action === 'delete') {
                        title = 'Delete Loan Request';
                        message = `Delete ${name}? This cannot be undone.`;
                        buttonClass = 'btn-danger';
                        iconClass = 'delete';
                        icon = 'bi-trash-fill';
                    }

                    titleEl.textContent = title;
                    messageEl.textContent = message;
                    submitBtn.className = `btn ${buttonClass}`;
                    iconEl.className = `action-confirm-icon ${iconClass}`;
                    iconEl.innerHTML = `<i class="bi ${icon}"></i>`;

                    modal.show();
                });
            });

            submitBtn.addEventListener('click', function () {
                if (targetForm) {
                    targetForm.submit();
                }
            });
        });
    </script>
}