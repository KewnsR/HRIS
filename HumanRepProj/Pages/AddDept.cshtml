@page
@model HumanRepProj.Pages.AddDeptModel
@{
    ViewData["Title"] = "Add Department - HRIS";
    Layout = "_Layout";
}

<div class="container-fluid p-0">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow mt-4 mb-4">
                <div class="card-body p-4">
                    <h1 class="text-center mb-4">Add Department</h1>
                    <hr />

                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Input.TemplateKey" class="form-label">Department Template</label>
                                <select asp-for="Input.TemplateKey" id="departmentTemplate" class="form-select" asp-items="Model.DepartmentTemplates">
                                    <option value="">-- Select Template (auto-fill name and description) --</option>
                                </select>
                                <small class="text-muted">Use a template to auto-fill department name and description.</small>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Input.Name" class="form-label">Department Name</label>
                                <input asp-for="Input.Name" class="form-control" />
                                <span asp-validation-for="Input.Name" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-12">
                                <label asp-for="Input.Description" class="form-label">Description</label>
                                <textarea asp-for="Input.Description" class="form-control" rows="3"></textarea>
                                <span asp-validation-for="Input.Description" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-dark">Create Department</button>
                            <a asp-page="/Departments" class="btn btn-outline">Back to Departments</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const templateSelect = document.getElementById('departmentTemplate');
            const nameInput = document.getElementById('Input_Name');
            const descInput = document.getElementById('Input_Description');

            if (!templateSelect || !nameInput || !descInput) {
                return;
            }

            const templates = {
                it: {
                    name: 'IT Department',
                    description: 'Handles systems, infrastructure, software support, and cybersecurity operations.'
                },
                hr: {
                    name: 'Human Resources',
                    description: 'Manages recruitment, employee records, performance processes, and workforce development.'
                },
                finance: {
                    name: 'Finance',
                    description: 'Responsible for budgeting, payroll oversight, reporting, and financial controls.'
                },
                operations: {
                    name: 'Operations',
                    description: 'Oversees day-to-day workflows, process execution, and service delivery.'
                },
                sales: {
                    name: 'Sales',
                    description: 'Drives revenue generation, client acquisition, and account relationship management.'
                }
            };

            templateSelect.addEventListener('change', function () {
                const key = (templateSelect.value || '').toLowerCase();
                const selected = templates[key];
                if (!selected) {
                    return;
                }

                nameInput.value = selected.name;
                descInput.value = selected.description;
            });
        })();
    </script>
}