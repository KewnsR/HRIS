@page
@model HumanRepProj.Pages.UserDashboardModel
@{
    ViewData["Title"] = "Employee Dashboard";
    string currentPath = HttpContext.Request.Path;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - HR Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --primary: #0f4c81;
            --primary-hover: #0c3f6b;
            --primary-light: #e6f0f9;
            --secondary: #5f6c82;
            --success: #10b981;
            --danger: #ef4444;
            --warning: #f59e0b;
            --info: #2563eb;
            --dark: #0f172a;
            --light: #f8fafc;
            --sidebar-width: 280px;
            --header-height: 70px;
            --transition: all 0.3s ease;
            --shadow-sm: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            --shadow: 0 1px 3px 0 rgba(0, 0, 0, 0.1), 0 1px 2px 0 rgba(0, 0, 0, 0.06);
            --shadow-lg: 0 14px 40px rgba(15, 23, 42, 0.08);
            --border-radius: 0.5rem;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Inter', 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        body {
            background: radial-gradient(circle at 20% 0%, #f5f9ff 0%, #eef2f7 48%, #edf1f8 100%);
            color: #1e293b;
            font-size: 0.875rem;
        }

        /* Layout */
        .app-container {
            display: flex;
            min-height: 100vh;
        }

        /* Consistent Sidebar UI */
        .sidebar {
            width: var(--sidebar-width);
            background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
            color: #e2e8f0;
            flex-shrink: 0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100%;
            left: 0;
            top: 0;
            z-index: 1000;
            transition: var(--transition);
            overflow-x: hidden;
            overflow-y: auto;
            padding: 1.5rem;
            border-right: 1px solid rgba(148, 163, 184, 0.24);
        }

        .sidebar-header {
            margin-bottom: 2rem;
            padding-bottom: 1rem;
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
        }

        .brand {
            font-size: 1.25rem;
            font-weight: 700;
            color: #f8fafc;
            text-align: center;
        }

        .sidebar-user {
            display: flex;
            flex-direction: column;
            gap: 0.25rem;
            margin-bottom: 2rem;
            padding-bottom: 2rem;
            border-bottom: 1px solid rgba(148, 163, 184, 0.24);
            text-align: center;
        }

        .user-name {
            font-size: 1.125rem;
            font-weight: 600;
            color: #f8fafc;
        }

        .user-role {
            color: #94a3b8;
            font-size: 0.875rem;
        }

        .nav-title {
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
            color: #93c5fd;
            margin-bottom: 1rem;
            font-weight: 600;
            padding-left: 0.75rem;
        }

        .sidebar-nav ul {
            list-style: none;
            margin-bottom: 2rem;
        }

        .sidebar-nav li {
            margin-bottom: 0.5rem;
        }

        .sidebar-nav a {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            padding: 0.75rem;
            color: rgba(226, 232, 240, 0.92);
            text-decoration: none;
            transition: var(--transition);
            border-radius: var(--border-radius);
        }

        .sidebar-nav a:hover {
            background-color: rgba(59, 130, 246, 0.18);
            color: #ffffff;
        }

            .sidebar-nav a.active {
                background-color: rgba(59, 130, 246, 0.3);
                color: #ffffff;
                font-weight: 600;
            }

            .sidebar-nav a i {
                width: 20px;
                text-align: center;
            }

        .sidebar-footer {
            margin-top: auto;
            padding-top: 1rem;
            border-top: 1px solid rgba(148, 163, 184, 0.24);
        }

            .sidebar-footer a {
                display: flex;
                align-items: center;
                gap: 0.75rem;
                padding: 0.75rem;
                color: rgba(226, 232, 240, 0.92);
                text-decoration: none;
                transition: var(--transition);
                border-radius: var(--border-radius);
            }

                .sidebar-footer a:hover {
                    background-color: rgba(239, 68, 68, 0.22);
                    color: #ffffff;
                }

        /* Main Content */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-width);
            display: flex;
            flex-direction: column;
            min-width: 0;
            min-height: 100vh;
        }

        /* Top Navigation */
        .top-nav {
            height: var(--header-height);
            background-color: rgba(255, 255, 255, 0.92);
            backdrop-filter: blur(6px);
            box-shadow: var(--shadow);
            display: flex;
            align-items: center;
            justify-content: flex-start;
            padding: 0 2rem;
            position: sticky;
            top: 0;
            z-index: 100;
            border-bottom: 1px solid #e2e8f0;
        }

        .top-nav-left {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .section-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.4rem 0.8rem;
            background: var(--primary-light);
            color: var(--primary);
            border: 1px solid #c7ddf2;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            letter-spacing: 0.02em;
        }

        /* Content Container */
        .content-container {
            width: min(1280px, 100%);
            margin: 0 auto;
            padding: 2rem 2rem 2.25rem;
            flex-grow: 1;
        }

        .dashboard-shell {
            display: grid;
            grid-template-columns: minmax(0, 2fr) minmax(280px, 1fr);
            gap: 1.5rem;
            align-items: start;
        }

        .main-stack,
        .side-stack {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }

        /* Dashboard Specific Styles */
        .dashboard-header {
            margin-bottom: 0.2rem;
        }

            .dashboard-header h1 {
                font-size: 1.9rem;
                font-weight: 700;
                letter-spacing: -0.015em;
                margin-bottom: 0.35rem;
            }

        .dashboard-header p {
            color: #5b6b82;
            font-size: 0.98rem;
        }

        .quick-actions {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            margin-bottom: 1.5rem;
        }

        .quick-action {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
            background: white;
            border: 1px solid #e2e8f0;
            border-radius: var(--border-radius);
            padding: 0.95rem 1rem;
            color: #334155;
            font-weight: 600;
            text-decoration: none;
            transition: var(--transition);
        }

        .quick-action:hover {
            border-color: #bcd0e5;
            box-shadow: 0 8px 18px rgba(15, 23, 42, 0.08);
            transform: translateY(-2px);
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
            gap: 1rem;
        }

        .stat-card {
            display: block;
            background: white;
            border-radius: var(--border-radius);
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow-sm);
            padding: 1.5rem;
            text-align: center;
            text-decoration: none;
            color: inherit;
            transition: var(--transition);
        }

        .stat-card:hover {
            transform: translateY(-3px);
            border-color: #cdd8e7;
            box-shadow: 0 10px 24px rgba(15, 23, 42, 0.08);
        }

        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            margin-bottom: 0.5rem;
            color: var(--dark);
        }

        .stat-label {
            font-size: 0.875rem;
            color: var(--secondary);
        }

        .activity-card {
            background: white;
            border-radius: var(--border-radius);
            border: 1px solid #e2e8f0;
            box-shadow: var(--shadow-sm);
            padding: 1.5rem;
        }

            .activity-card h2 {
                font-size: 1.25rem;
                font-weight: 600;
                margin-bottom: 1.5rem;
            }

        .summary-card {
            background: linear-gradient(145deg, #0f4c81 0%, #1a6aa9 100%);
            border-radius: 14px;
            color: #ffffff;
            padding: 1.35rem;
            box-shadow: var(--shadow-lg);
        }

        .summary-card h3 {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: 0.75rem;
        }

        .summary-meta {
            display: grid;
            gap: 0.65rem;
            margin-top: 0.75rem;
        }

        .summary-meta-item {
            display: flex;
            justify-content: space-between;
            gap: 0.75rem;
            font-size: 0.84rem;
            background: rgba(255, 255, 255, 0.14);
            border: 1px solid rgba(255, 255, 255, 0.2);
            border-radius: 8px;
            padding: 0.5rem 0.65rem;
        }

        .tip-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 14px;
            padding: 1.1rem 1.1rem;
            box-shadow: var(--shadow-sm);
        }

        .tip-card h4 {
            font-size: 0.95rem;
            margin-bottom: 0.55rem;
            color: #0f172a;
        }

        .tip-card p {
            margin: 0;
            color: #5b6b82;
            line-height: 1.5;
        }

        .sidebar-toggle {
            display: none;
            background: transparent;
            border: none;
            color: #0f172a;
            font-size: 1.2rem;
            cursor: pointer;
        }

        .activity-item {
            padding: 1rem 0;
            border-bottom: 1px solid #e2e8f0;
        }

            .activity-item:last-child {
                border-bottom: none;
            }

        .activity-title {
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .activity-description {
            color: #475569;
            margin-bottom: 0.5rem;
            font-size: 0.875rem;
        }

        .activity-time {
            color: #64748b;
            font-size: 0.75rem;
            font-style: italic;
        }

        /* Logout Popup Styles */
        .logout-popup {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 2000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

            .logout-popup.active {
                opacity: 1;
                visibility: visible;
            }

        .logout-popup-content {
            background-color: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
            width: 90%;
            max-width: 320px;
            transform: translateY(-20px);
            transition: transform 0.3s ease;
        }

        .logout-popup.active .logout-popup-content {
            transform: translateY(0);
        }

        .logout-popup-body {
            padding: 1.5rem;
            text-align: center;
        }

            .logout-popup-body p {
                margin: 0 0 1.5rem 0;
                font-size: 1rem;
                color: #333;
            }

        .logout-popup-buttons {
            display: flex;
            justify-content: center;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }

        .btn {
            padding: 0.5rem 1.5rem;
            border-radius: 4px;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            border: none;
            min-width: 80px;
        }

        .btn-cancel {
            background-color: #ff5252;
            color: white;
        }

            .btn-cancel:hover {
                background-color: #ff1a1a;
            }

        .btn-confirm {
            background-color: #4caf50;
            color: white;
        }

            .btn-confirm:hover {
                background-color: #45a049;
            }

        /* Responsive */
        @@media (max-width: 768px) {
            .sidebar

        {
            transform: translateX(-100%);
            position: fixed;
            width: 280px;
            z-index: 1001;
        }

        .sidebar.open {
            transform: translateX(0);
        }

        .main-content {
            margin-left: 0;
        }

        .top-nav {
            justify-content: space-between;
            padding: 0 1rem;
        }

        .sidebar-toggle {
            display: inline-flex;
        }

        .section-pill {
            display: none;
        }

        .content-container {
            padding: 1rem;
        }

        .dashboard-shell {
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .quick-actions {
            grid-template-columns: 1fr;
        }

        .dashboard-header h1 {
            font-size: 1.45rem;
        }

        .stats-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        }

        @@media (max-width: 520px) {
            .stats-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="app-container">
        <!-- Consistent Sidebar UI -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="brand">HR Portal</div>
            </div>

            <div class="sidebar-user">
                <div class="user-name">@Model.FullName</div>
                <div class="user-role">@Model.Role</div>
            </div>

            <nav class="sidebar-nav">
                <p class="nav-title">Main Menu</p>
                <ul>
                    <li>
                        <a asp-page="/UserDashboard" class="active">
                            <i class="fas fa-th-large"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/UserProfile">
                            <i class="fas fa-user"></i>
                            <span>My Profile</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/UserLeaveRequest">
                            <i class="fas fa-calendar-alt"></i>
                            <span>Leave Request</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/Attendance/RecordAttendance">
                            <i class="fas fa-clock"></i>
                            <span>Attendance</span>
                        </a>
                    </li>
                    <li>
                        <a asp-page="/UserLoanRequest">
                            <i class="fas fa-hand-holding-usd"></i>
                            <span>Loan Request</span>
                        </a>
                    </li>
                </ul>
            </nav>

            <div class="sidebar-footer">
                <a href="/UserLogin?logout=true" id="logoutBtn">
                    <i class="fas fa-sign-out-alt"></i>
                    <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <!-- Top Navigation -->
            <header class="top-nav">
                <div class="top-nav-left">
                    <button type="button" class="sidebar-toggle" aria-label="Toggle menu">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="section-pill"><i class="fas fa-compass"></i> Employee Workspace</span>
                </div>
            </header>

            <!-- Page Content -->
            <div class="content-container">
                <div class="dashboard-shell">
                    <section class="main-stack">
                        <div class="dashboard-header">
                            <h1>Employee Dashboard</h1>
                            <p>Welcome back, @Model.FullName. Here is a snapshot of your account today.</p>
                        </div>

                        <div class="quick-actions">
                            <a asp-page="/Attendance/RecordAttendance" class="quick-action"><i class="fas fa-clock"></i> Check In/Out</a>
                            <a asp-page="/UserLeaveRequest" class="quick-action"><i class="fas fa-calendar-plus"></i> Request Leave</a>
                            <a asp-page="/UserLoanRequest" class="quick-action"><i class="fas fa-file-invoice-dollar"></i> Apply Loan</a>
                            <a asp-page="/UserProfile" class="quick-action"><i class="fas fa-id-badge"></i> Update Profile</a>
                        </div>

                        <div class="stats-grid">
                            <a asp-page="/UserLeaveRequest" class="stat-card">
                                <div class="stat-value">@Model.AvailableLeaveDays</div>
                                <div class="stat-label">Available Leave Days</div>
                            </a>
                            <a asp-page="/UserLoanRequest" class="stat-card">
                                <div class="stat-value">@Model.PendingTasks</div>
                                <div class="stat-label">Pending Tasks</div>
                            </a>
                            <a asp-page="/UserProfile" class="stat-card">
                                <div class="stat-value">@Model.DocumentUpdates</div>
                                <div class="stat-label">Document Updates</div>
                            </a>
                        </div>

                        <div class="activity-card">
                            <h2>Recent Activities</h2>

                            <div class="activity-item">
                                <div class="activity-title">Leave Request Approved</div>
                                <div class="activity-description">Your leave request from May 15 to May 18 has been approved by HR Manager.</div>
                                <div class="activity-time">2 hours ago</div>
                            </div>

                            <div class="activity-item">
                                <div class="activity-title">Salary Credited</div>
                                <div class="activity-description">Your salary for April 2025 has been credited to your bank account.</div>
                                <div class="activity-time">1 day ago</div>
                            </div>

                            <div class="activity-item">
                                <div class="activity-title">Document Update Required</div>
                                <div class="activity-description">Please update your address proof document as it has expired.</div>
                                <div class="activity-time">2 days ago</div>
                            </div>
                        </div>
                    </section>

                    <aside class="side-stack">
                        <div class="summary-card">
                            <h3>Account Snapshot</h3>
                            <div>Role: @Model.Role</div>
                            <div class="summary-meta">
                                <div class="summary-meta-item"><span>Leave Balance</span><strong>@Model.AvailableLeaveDays days</strong></div>
                                <div class="summary-meta-item"><span>Pending Items</span><strong>@Model.PendingTasks</strong></div>
                                <div class="summary-meta-item"><span>Profile Updates</span><strong>@Model.DocumentUpdates</strong></div>
                            </div>
                        </div>

                        <div class="tip-card">
                            <h4>Tip</h4>
                            <p>Keep your profile details current to speed up approvals for leave and loan requests.</p>
                        </div>

                        <div class="tip-card">
                            <h4>Need Action?</h4>
                            <p>Use the quick actions above to file requests and monitor their status from this dashboard.</p>
                        </div>
                    </aside>
                </div>
            </div>
        </main>
    </div>

    <div id="logoutPopup" class="logout-popup">
        <div class="logout-popup-content">
            <div class="logout-popup-body">
                <p>Are you sure you want to log out?</p>
                <div class="logout-popup-buttons">
                    <button id="confirmLogout" class="btn btn-confirm">Yes</button>
                    <button id="cancelLogout" class="btn btn-cancel">Cancel</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        // Mobile sidebar toggle functionality
        document.addEventListener('DOMContentLoaded', function() {
            const sidebarToggle = document.querySelector('.sidebar-toggle');

            const sidebar = document.querySelector('.sidebar');

            if (sidebarToggle && sidebar) {
                sidebarToggle.addEventListener('click', function() {
                    sidebar.classList.toggle('open');
                });
            }

            // Logout popup functionality
            const logoutButton = document.getElementById('logoutBtn');
            const logoutPopup = document.getElementById('logoutPopup');
            const cancelLogout = document.getElementById('cancelLogout');
            const confirmLogout = document.getElementById('confirmLogout');

            // Store the original logout URL
            const logoutUrl = logoutButton.getAttribute('href');

            // Prevent default navigation and show popup instead
            logoutButton.addEventListener('click', function(e) {
                e.preventDefault();
                logoutPopup.classList.add('active');
            });

            // Close popup when clicking the cancel button
            cancelLogout.addEventListener('click', function() {
                logoutPopup.classList.remove('active');
            });

            // Confirm logout and redirect
            confirmLogout.addEventListener('click', function() {
                window.location.href = logoutUrl;
            });

            // Close popup when clicking outside
            logoutPopup.addEventListener('click', function(e) {
                if (e.target === logoutPopup) {
                    logoutPopup.classList.remove('active');
                }
            });

            // Close popup when pressing Escape key
            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape' && logoutPopup.classList.contains('active')) {
                    logoutPopup.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>